# PostOracle — Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# Required: OpenAI API key for image generation (GPT-image-2)
OPENAI_API_KEY=

# Required: HeyGen API key for presenter video generation
HEYGEN_API_KEY=

# Required: Pexels API key for b-roll and stock images
PEXELS_API_KEY=

# Optional: Pixabay API key (fallback stock images)
PIXABAY_API_KEY=

# Optional: ElevenLabs API key (voice synthesis for video-use skill)
ELEVENLABS_API_KEY=
